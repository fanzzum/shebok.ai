# ─── Groq (Whisper + DeepSeek-R1) ───────────────────────────────────────────
# https://console.groq.com → API Keys
GROQ_API_KEY=

# ─── Together.ai (Meditron-7B) ──────────────────────────────────────────────
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# ─── Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Twilio WhatsApp Sandbox ────────────────────────────────────────────────
# console.twilio.com → Account Info + Messaging → WhatsApp Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Hugging Face (model downloads) ─────────────────────────────────────────
# huggingface.co → Settings → Access Tokens
HF_TOKEN=

# ─── n8n / Webhooks ─────────────────────────────────────────────────────────
# Set after running: cloudflared tunnel --url http://localhost:5678
N8N_WEBHOOK_URL=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ─── Local ML services ────────────────────────────────────────────────────────
BANGLABERT_URL=http://localhost:5001
BIOBERT_URL=http://localhost:5002

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
