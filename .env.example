# ─── Groq (Whisper + DeepSeek-R1) ───────────────────────────────────────────
# https://console.groq.com → API Keys
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ─── Supabase ───────────────────────────────────────────────────────────────
# https://supabase.com → Project Settings → API
# Project URL only — no /rest/v1/ suffix
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── WhatsApp Cloud API (Meta — direct, no Twilio) ─────────────────────────
# developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=shebok_webhook_verify
WHATSAPP_API_VERSION=v21.0

# ─── Hugging Face (model downloads) ─────────────────────────────────────────
HF_TOKEN=

# ─── n8n / ngrok ────────────────────────────────────────────────────────────
# ngrok http 80   (or 5678 if using make n8n-up)
NGROK_URL=
N8N_WEBHOOK_URL=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ─── Local ML services ────────────────────────────────────────────────────────
BANGLABERT_URL=http://localhost:5001
BIOBERT_URL=http://localhost:5002

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
